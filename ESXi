#!/usr/bin/env python3
import ssl
import argparse
import sys
import time
from pyVim import connect
from pyVmomi import vim

# Парсинг аргументов командной строки
ap = argparse.ArgumentParser(description="Execute command on ESXi guest VM")
ap.add_argument("--host", required=True, help="ESXi host IP address")
ap.add_argument("--user", required=True, help="ESXi username")
ap.add_argument("--password", required=True, help="ESXi password")
ap.add_argument("--vm", required=True, help="Virtual machine name")
ap.add_argument("--guest-user", required=True, help="Guest OS username")
ap.add_argument("--guest-pass", required=True, help="Guest OS password")
ap.add_argument("--cmd", required=True, help="Command to execute")
ap.add_argument("--args", default="", help="Command arguments")

args = ap.parse_args()

# Подключение к ESXi
try:
    context = ssl._create_unverified_context()
    si = connect.SmartConnect(
        host=args.host,
        user=args.user,
        pwd=args.password,
        sslContext=context
    )
    print(f"Connected to {args.host}")
except Exception as e:
    print(f"Connection failed: {e}")
    sys.exit(1)

# Поиск виртуальной машины
try:
    content = si.RetrieveContent()
    container_view = content.viewManager.CreateContainerView(
        content.rootFolder,
        [vim.VirtualMachine],
        True
    )
    
    vm = None
    for virtual_machine in container_view.view:
        if virtual_machine.name == args.vm:
            vm = virtual_machine
            break
    
    if vm is None:
        print(f"VM '{args.vm}' not found!")
        connect.Disconnect(si)
        sys.exit(1)
        
    print(f"Found VM: {vm.name}")
    
except Exception as e:
    print(f"Error finding VM: {e}")
    connect.Disconnect(si)
    sys.exit(1)

# Выполнение команды в гостевой ОС
try:
    pm = content.guestOperationsManager.processManager
    
    # Аутентификация в гостевой ОС
    auth = vim.NamePasswordAuthentication(
        username=args.guest_user,
        password=args.guest_pass
    )
    
    # Спецификация программы
    program_spec = vim.vm.guest.ProcessManager.ProgramSpec(
        programPath=args.cmd,
        arguments=args.args
    )
    
    # Запуск программы
    print(f"Executing: {args.cmd} {args.args}")
    pid = pm.StartProgramInGuest(vm, auth, program_spec)
    print(f"Started PID: {pid}")
    
    # Ожидание и проверка результата
    time.sleep(2)
    
    # Получение информации о процессе
    process_info = pm.ListProcessesInGuest(vm, auth, [pid])
    if process_info:
        exit_code = process_info[0].exitCode
        print(f"Exit code: {exit_code}")
    else:
        print("Process not found")
        
except Exception as e:
    print(f"Error executing command: {e}")

# Отключение
finally:
    connect.Disconnect(si)
    print("Disconnected")


